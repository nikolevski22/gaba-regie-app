# PostgreSQL — z. B. Neon / Supabase / Coolify-Postgres
DATABASE_URL="postgresql://user:pass@host:5432/gaba_regie?schema=public"

# Auth.js — mit `openssl rand -base64 32` generieren
AUTH_SECRET="change-me"
# Öffentliche URL der App (für Auth-Callbacks)
AUTH_URL="http://localhost:3000"

# SMTP-Versand (z. B. gaba-ag.ch-Postfach oder SendGrid)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Gandola & Battaini AG <info@gaba-ag.ch>"
# Im MVP ohne echten SMTP: "true" -> E-Mails werden nur geloggt, nicht versendet
SMTP_DRY_RUN="true"

# Speicherort der hochgeladenen Baustellenfotos (persistentes Volume)
UPLOAD_DIR="./uploads"

# Erst-Admin (wird beim Seed angelegt)
SEED_ADMIN_EMAIL="admin@gaba-ag.ch"
SEED_ADMIN_PASSWORD="changeme123"
