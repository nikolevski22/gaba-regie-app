// Prisma-Datenmodell — Regiebericht-App Gandola & Battaini AG
// Basis: EXCEL_ANALYSE.md + MVP_PLAN.md
// DB: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
//  Benutzer / Auth
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reports     Report[]     @relation("ReportAuthor")
  collections Collection[] @relation("CollectionAuthor")
}

enum UserRole {
  ADMIN
  USER
}

// ─────────────────────────────────────────────
//  Stammdaten: Artikelkatalog (Import aus "Gesamte Liste.xlsx")
// ─────────────────────────────────────────────

model Resource {
  id          String           @id @default(cuid())
  artikelNr   String                       // z. B. "2.271.301"
  bezeichnung String
  kategorie   ResourceCategory             // abgeleitet aus Artikel-Präfix
  einheit     String                       // Std, Tag, m², S, Stk, Rl ...
  preis       Decimal          @db.Decimal(12, 2)
  mengenHint  String?                      // z. B. "S=25kg"
  kapitel     String?
  aktiv       Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  reportLines ReportLine[]
  employees   Employee[]                   // Mitarbeiter mit Standard-Lohnansatz

  // Der Quellkatalog enthält echte Duplikate (gleiche Artikel-Nr. mit
  // unterschiedlicher Bezeichnung/Einheit). Daher kein striktes Unique auf
  // artikelNr — Dedup erfolgt im Import über (artikelNr+einheit+bezeichnung).
  @@unique([artikelNr, einheit, bezeichnung])
  @@index([artikelNr])
  @@index([kategorie])
  @@index([bezeichnung])
}

// Kategorie aus Artikelnummer-Präfix:
// 1.021.* = LABOR | 3.041/3.042.* = MACHINE | 6.031.* = VEHICLE
// 6.032.* = DISPOSAL | 2/4/5.* = MATERIAL
enum ResourceCategory {
  LABOR
  MACHINE
  VEHICLE
  MATERIAL
  DISPOSAL
  OTHER
}

// ─────────────────────────────────────────────
//  Stammdaten: Mitarbeiter (eigene Entität, bestätigt)
// ─────────────────────────────────────────────

model Employee {
  id         String   @id @default(cuid())
  vorname    String
  nachname   String?
  funktion   String                        // z. B. "Vorarbeiter", "Gipser", "Maler"
  aktiv      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Standard-Lohnansatz: Verweis auf eine LABOR-Resource (Funktion + Preis)
  resourceId String?
  resource   Resource? @relation(fields: [resourceId], references: [id])

  reportLines ReportLine[]
}

// ─────────────────────────────────────────────
//  Kunde / Projekt (leichtgewichtig)
// ─────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  name      String                          // Bauleitung / Auftraggeber
  email     String?
  uReferenz String?                         // U. Ref. (für ZS)
  createdAt DateTime @default(now())

  projects Project[]
  reports  Report[]
}

model Project {
  id         String   @id @default(cuid())
  name       String                         // Objekt / Baustelle
  adresse    String?
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  createdAt  DateTime @default(now())

  reports Report[]
}

// ─────────────────────────────────────────────
//  Regiebericht (Rapport-Seite) — Herzstück
// ─────────────────────────────────────────────

model Report {
  id        String       @id @default(cuid())
  // Rapport-Nr. wird manuell erfasst. Basis + Suffix getrennt, damit
  // mehrere Suffixe (z. B. -1, -2, -5) auf dieselbe Basisnummer möglich sind.
  rapportBasis  String?                      // z. B. "25100002"
  rapportSuffix String?                      // z. B. "5"
  rapportNr     String?                      // Anzeige-Wert "25100002-5" (abgeleitet)
  status    ReportStatus @default(ENTWURF)

  // Kopfdaten
  datum               DateTime
  kw                  Int?                    // Kalenderwoche
  bauleitung          String?
  objekt              String?
  leistung            String?
  titel               String?
  ausgefuehrteArbeiten String?  @db.Text       // mehrzeiliger Freitext

  // Tagesspalten-Header: Startdatum der Woche (übrige 5 werden abgeleitet)
  wochenStart DateTime?

  // Abzüge / Steuer (kaskadierend, siehe lib/calc)
  rabattPct Decimal @default(0)   @db.Decimal(6, 4)  // z. B. 0.05 = 5%
  skontoPct Decimal @default(0)   @db.Decimal(6, 4)
  abzugPct  Decimal @default(0)   @db.Decimal(6, 4)
  mwstPct   Decimal @default(0.081) @db.Decimal(6, 4)
  zeigeAbzuege Boolean @default(false)        // Abzugsblock im PDF ein/aus

  // Gespeicherte Summen (denormalisiert für schnelle Listen; Quelle = lib/calc)
  bruttoTotal   Decimal @default(0) @db.Decimal(12, 2)
  nettoInklMwst Decimal @default(0) @db.Decimal(12, 2)

  // Beziehungen
  authorId     String?
  author       User?       @relation("ReportAuthor", fields: [authorId], references: [id])
  customerId   String?
  customer     Customer?   @relation(fields: [customerId], references: [id])
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id])
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id])

  lines    ReportLine[]
  photos   ReportPhoto[]
  emails   EmailLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([datum])
  @@index([rapportBasis])
}

enum ReportStatus {
  ENTWURF
  GESENDET
  UNTERZEICHNET
  ABGERECHNET
}

// Position im Regiebericht
model ReportLine {
  id          String     @id @default(cuid())
  reportId    String
  report      Report     @relation(fields: [reportId], references: [id], onDelete: Cascade)

  // Ressourcenbezug (Default-Preis), aber alles überschreibbar
  resourceId  String?
  resource    Resource?  @relation(fields: [resourceId], references: [id])
  artikelNr   String?                          // Snapshot
  bezeichnung String                           // ggf. mit Mitarbeitername ergänzt
  gruppe      LineGroup                        // Untergruppierung im PDF

  // Optionaler Mitarbeiterbezug (bei Lohnpositionen)
  employeeId  String?
  employee    Employee?  @relation(fields: [employeeId], references: [id])

  // 6 Tageswerte (Mo–Sa). Anzahl = Summe, falls erfasst.
  tag1 Decimal? @db.Decimal(10, 2)
  tag2 Decimal? @db.Decimal(10, 2)
  tag3 Decimal? @db.Decimal(10, 2)
  tag4 Decimal? @db.Decimal(10, 2)
  tag5 Decimal? @db.Decimal(10, 2)
  tag6 Decimal? @db.Decimal(10, 2)

  einheit String
  anzahl  Decimal @db.Decimal(10, 2)          // = Σ Tageswerte oder manuell
  preis   Decimal @db.Decimal(12, 2)          // Default aus Resource, überschreibbar
  total   Decimal @db.Decimal(12, 2)          // = round2(anzahl * preis)

  sortIndex Int @default(0)

  @@index([reportId])
}

// Untergruppen entsprechen den Blöcken im Rapport
enum LineGroup {
  PERSONAL
  MASCHINE
  FAHRZEUG
  MATERIAL
  SONSTIGES
}

// Baustellenfotos
model ReportPhoto {
  id        String   @id @default(cuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  url       String                            // Storage-Pfad / URL
  sortIndex Int      @default(0)
  createdAt DateTime @default(now())

  @@index([reportId])
}

// ─────────────────────────────────────────────
//  Sammelrapport (ZS / TOTAL)
// ─────────────────────────────────────────────

model Collection {
  id        String   @id @default(cuid())
  name      String                            // Report Name / Titel
  datum     DateTime @default(now())
  uReferenz String?                           // U. Ref.
  email     String?                           // Empfänger
  status    ReportStatus @default(ENTWURF)

  // gleiche Abzugs-/MwSt-Logik wie Report
  rabattPct Decimal @default(0)     @db.Decimal(6, 4)
  skontoPct Decimal @default(0)     @db.Decimal(6, 4)
  abzugPct  Decimal @default(0)     @db.Decimal(6, 4)
  mwstPct   Decimal @default(0.081) @db.Decimal(6, 4)

  bruttoTotal   Decimal @default(0) @db.Decimal(12, 2)
  nettoInklMwst Decimal @default(0) @db.Decimal(12, 2)

  authorId String?
  author   User?    @relation("CollectionAuthor", fields: [authorId], references: [id])

  reports Report[]
  emails  EmailLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
//  Versand-Historie
// ─────────────────────────────────────────────

model EmailLog {
  id           String   @id @default(cuid())
  reportId     String?
  report       Report?     @relation(fields: [reportId], references: [id])
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id])

  empfaenger String                           // Komma-getrennte Empfänger
  betreff    String
  pdfPfad    String?                          // gespeichertes PDF
  status     EmailStatus @default(GESENDET)
  fehler     String?
  gesendetAm DateTime @default(now())

  @@index([reportId])
}

enum EmailStatus {
  GESENDET
  FEHLGESCHLAGEN
}
